# ============================================
# LangChain RAG 系统 - 环境配置
# 复制此文件为 .env 并修改实际值
# ============================================

# 应用配置
DEBUG=true

# MySQL配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=rag_db

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Milvus配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_base

# JWT密钥（生产环境务必修改！）
JWT_SECRET_KEY=langchain-rag-secret-key-change-in-production-2024

# LLM提供商: tongyi 或 zhipu
LLM_PROVIDER=tongyi

# 通义千问 API Key
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 智谱GLM API Key
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
